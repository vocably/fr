{"transcript":"ɛk.spo.nɑ̃.sjɛl","exists":true,"definitions":["Qui croît ou décroît très rapidement, de manière proportionnelle à sa valeur actuelle.","Relatif à une fonction exponentielle.","Qui a la forme d'une exponentielle."],"examples":["La croissance démographique est exponentielle.","Une courbe exponentielle.","Développement exponentiel des technologies."],"lemma":"exponentiel","lemmaPos":"adjective","synonyms":["rapide","fulgurant","vertigineux"],"number":"singular","gender":"feminine","source":"exponentielle"}