{"transcript":"pɔ.se.dɛ","exists":true,"definitions":["Avaient la propriété de quelque chose.","Jouissaient d'une faculté ou d'un avantage.","Étaient sous l'emprise d'une force ou d'une émotion."],"examples":["Ils possédaient une vaste demeure.","Elles possédaient un talent rare.","Les démons les possédaient."],"lemma":"posséder","lemmaPos":"verb","synonyms":["avaient","détenaient","jouissaient","disposaient"],"number":"plural","pastTenses":"possédèrent, ont possédé","tense":"past","source":"possédaient"}