{"transcript":"ɛ̃.pʁe.vy","exists":true,"definitions":["Qui n'a pas été prévu, inattendu.","Qui survient sans qu'on s'y attende."],"examples":["Une dépense imprévue.","Une rencontre imprévue.","Des conséquences imprévues."],"lemma":"imprévu","lemmaPos":"adjective","synonyms":["inattendu","soudain","fortuit","subit"],"number":"singular","gender":"feminine","source":"imprévue"}