{"transcript":"de.ɡaʁ.ni","exists":true,"definitions":["Dépouillé de ce qui garnissait.","Devenu chauve ou moins fourni.","Action de retirer les ornements ou les troupes d'un lieu."],"examples":["Il a dégarni les étagères.","Le général a dégarni ses lignes.","Le vent a dégarni les arbres."],"lemma":"dégarnir","lemmaPos":"verb","synonyms":["dépouiller","vider","dépeupler","dégarnir"],"number":"singular","pastTenses":"dégarnit, a dégarni","tense":"past","gender":"masculine","source":"dégarni"}